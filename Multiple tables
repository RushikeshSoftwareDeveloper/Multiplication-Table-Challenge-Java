
import java.util.Random;
import java.util.Scanner;

public class MultiplicationChallenge {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        Random random = new Random();

        int score = 0;
        boolean gameRunning = true;

        System.out.println("🧮 Multiplication Table Challenge Game");
        System.out.println("Answer the multiplication questions!");

        while (gameRunning) {

            int num1 = random.nextInt(10) + 1;
            int num2 = random.nextInt(10) + 1;

            int correctAnswer = num1 * num2;

            System.out.println("\nQuestion: " + num1 + " x " + num2 + " = ?");
            System.out.print("Your answer: ");

            int userAnswer = sc.nextInt();

            if (userAnswer == correctAnswer) {
                score++;
                System.out.println("✅ Correct!");
            } else {
                System.out.println("❌ Wrong! Correct answer was: " + correctAnswer);
                gameRunning = false;
            }

            System.out.println("Score: " + score);
        }

        System.out.println("\n🎮 Game Over!");
        System.out.println("Final Score: " + score);

        sc.close();
    }
}
